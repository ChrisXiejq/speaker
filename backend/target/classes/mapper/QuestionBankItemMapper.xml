<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.speakingkiller.app.mapper.QuestionBankItemMapper">

    <resultMap id="QbMap" type="com.speakingkiller.app.model.entity.QuestionBankItem">
        <id column="id" property="id"/>
        <result column="season_label" property="seasonLabel"/>
        <result column="part" property="part"/>
        <result column="topic" property="topic"/>
        <result column="question_text" property="questionText"/>
        <result column="sort_order" property="sortOrder"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO question_bank_items (season_label, part, topic, question_text, sort_order)
        VALUES (#{seasonLabel}, #{part}, #{topic}, #{questionText}, #{sortOrder})
    </insert>

    <select id="findById" resultMap="QbMap">
        SELECT * FROM question_bank_items WHERE id = #{id}
    </select>

    <select id="count" resultType="long">
        SELECT COUNT(*) FROM question_bank_items
    </select>

    <select id="findBySeasonLabelAndPartOrderBySortOrderAsc" resultMap="QbMap">
        SELECT * FROM question_bank_items
        WHERE season_label = #{seasonLabel} AND part = #{part}
        ORDER BY sort_order ASC
    </select>

    <select id="findDistinctSeasonLabels" resultType="java.lang.String">
        SELECT DISTINCT season_label FROM question_bank_items ORDER BY season_label DESC
    </select>

    <select id="findByTopicContainingIgnoreCase" resultMap="QbMap">
        SELECT * FROM question_bank_items
        WHERE LOWER(topic) LIKE CONCAT('%', LOWER(#{q}), '%')
    </select>
</mapper>
