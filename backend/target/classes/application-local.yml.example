# 使用方式：复制为 application-local.yml 后填写密码与密钥（不使用环境变量）。
#
# cp src/main/resources/application-local.yml.example src/main/resources/application-local.yml
#
# 连接说明：
# - 在 本机（Mac/Windows）开发、连阿里云 MySQL：JDBC 主机用 ECS 公网 IP，不要用 172.31.x 内网 IP。
# - 在 ECS 上与 MySQL 同机运行后端：JDBC 主机用 127.0.0.1。
# - 远程连库：安全组放行 3306，宝塔中开启数据库远程访问并授权你的客户端 IP。

spring:
  datasource:
    url: jdbc:mysql://127.0.0.1:3306/speaker?useUnicode=true&characterEncoding=utf8&serverTimezone=UTC&connectTimeout=15000&socketTimeout=60000&allowPublicKeyRetrieval=true
    username: admin
    password: 请填写宝塔中该数据库用户密码
    driver-class-name: com.mysql.cj.jdbc.Driver

app:
  jwt:
    secret: 请填写至少32字符的随机串
  admin:
    # 非空时启用 /api/admin；与请求头 X-Admin-Key 一致（题库 PDF 导入等）
    api-key: ""
  dashscope:
    api-key: 请填写阿里云 DashScope API Key
  wechat:
    mini-app-id: ""
    mini-app-secret: ""
