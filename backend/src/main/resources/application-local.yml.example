# 使用方式：复制本文件为同目录下的 application-local.yml，填写密码与密钥。
# application-local.yml 已加入 .gitignore，不会被提交到 Git。
#
# cp src/main/resources/application-local.yml.example src/main/resources/application-local.yml

spring:
  datasource:
    url: jdbc:mysql://speaker-project-2b15.b.aivencloud.com:26791/defaultdb?useUnicode=true&characterEncoding=utf8&serverTimezone=UTC&sslMode=REQUIRED
    username: avnadmin
    password: 请填写Aiven控制台中的数据库密码
    driver-class-name: com.mysql.cj.jdbc.Driver
  sql:
    init:
      mode: always
      schema-locations: classpath:schema.sql

app:
  jwt:
    # 至少 32 字符的随机串，用于签发 JWT
    secret: 请填写你的JWT密钥
  dashscope:
    api-key: 请填写阿里云DashScope_API_Key
    # 可选：听说能力（Qwen3-ASR-Flash + CosyVoice），默认与 application.yml 一致
    # asr-model: qwen3-asr-flash
    # tts-model: cosyvoice-v3-flash
    # tts-voice: longanyang
  wechat:
    mini-app-id: ""
    mini-app-secret: ""
