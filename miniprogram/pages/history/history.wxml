<view class="wrap">
  <view wx:if="{{ !list.length }}" class="muted empty">暂无记录</view>
  <view class="item" wx:for="{{ list }}" wx:key="id" data-id="{{ item.id }}" bindtap="openDetail">
    <view class="row">
      <text class="tag">{{ item.part }}</text>
      <view class="row-right">
        <text class="muted small">{{ item.status }}</text>
        <text class="del-btn" catchtap="onDelete" data-id="{{ item.id }}">删除</text>
      </view>
    </view>
    <view class="topic">{{ item.topic || '（无主题）' }}</view>
    <view class="muted small">{{ item.startedAt }}</view>
  </view>
</view>
